---
import "../styles.css";

const base = import.meta.env.BASE_URL.endsWith("/") ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const asset = (path: string) => `${base}${path.replace(/^\//, "")}`;
const title = "AegisLock - Private Mac apps stay hidden";
const description =
  "AegisLock hides selected Mac apps on an unlocked Mac and reveals them only after Touch ID or Mac password. Safe Hide keeps work open, with local reports, focus sessions, schedules, trusted places, and agent-aware access.";
const canonicalUrl = "https://saminulldreinull.github.io/AegisLockSite/";
const repoUrl = "https://github.com/saminulldreinull/AegisLock";
const productSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "AegisLock",
  applicationCategory: "SecurityApplication",
  operatingSystem: "macOS",
  description,
  offers: {
    "@type": "Offer",
    price: "29",
    priceCurrency: "EUR",
    availability: "https://schema.org/InStock"
  },
  featureList: [
    "Touch ID or Mac password gate",
    "Safe Hide protection without quitting apps",
    "Focus-based relock and configurable unlock grace",
    "Focus Sessions for uninterrupted work",
    "Schedules and Trusted Places",
    "Agentic Work sessions with local approval",
    "Local Access Reports with integrity checks",
    "Watchdog keepalive and restore checks"
  ]
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#07080b" />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${canonicalUrl}og-image.png`} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${canonicalUrl}og-image.png`} />
    <title>{title}</title>
    <link rel="icon" type="image/png" href={asset("favicon.png")} />
    <link rel="apple-touch-icon" href={asset("apple-touch-icon.png")} />
    <link rel="manifest" href={asset("site.webmanifest")} />
    <script type="application/ld+json" set:html={JSON.stringify(productSchema).replace(/</g, "\\u003c")} />
  </head>
  <body>
    <header class="site-nav" aria-label="Primary navigation">
      <a class="brand" href="#top" aria-label="AegisLock home">
        <img src={asset("app-icon.png")} alt="" width="34" height="34" />
        <span>AegisLock</span>
      </a>
      <nav class="nav-links">
        <a href="#why">Why now</a>
        <a href="#protection">Protection</a>
        <a href="#automation">Automation</a>
        <a href="#reports">Reports</a>
        <a href="#pricing">Pricing</a>
      </nav>
      <a class="nav-cta" href={repoUrl} target="_blank" rel="noreferrer">Download</a>
    </header>

    <main id="top">
      <section class="hero" aria-labelledby="hero-title">
        <div class="hero-copy">
          <p class="eyebrow">Mac app privacy for unlocked sessions</p>
          <h1 id="hero-title">Keep your Mac open. Reveal private apps with <span class="touch-accent">Touch ID.</span></h1>
          <p class="hero-lede">
            AegisLock hides selected apps while your Mac stays unlocked. When someone opens Notes, Notion, a browser profile, or a private document, the app stays hidden until system authentication approves it.
          </p>
          <div class="hero-actions">
            <a class="button primary" href={repoUrl} target="_blank" rel="noreferrer">Download for Mac</a>
            <a class="button secondary" href="#security">Read the security model</a>
          </div>
          <div class="hero-points" aria-label="Core benefits">
            <span>Does not quit apps by default</span>
            <span>Local reports, no content logging</span>
            <span>Focus Sessions for uninterrupted work</span>
          </div>
        </div>

        <div class="hero-demo" aria-label="AegisLock product interface preview">
          <div class="privacy-window">
            <div class="window-bar" aria-hidden="true">
              <span></span><span></span><span></span>
              <b>Notion</b>
            </div>
            <div class="fake-app" aria-hidden="true">
              <aside class="fake-sidebar">
                <strong>Private</strong>
                <span>Journal</span>
                <span>Ideas</span>
                <span>Letters</span>
                <span>Archive</span>
              </aside>
              <article class="journal-entry">
                <span>Daily Journal</span>
                <h3>Morning notes</h3>
                <p>Keep this page private while Codex runs, downloads continue, and the Mac stays awake.</p>
                <ul>
                  <li>Finish assignment draft</li>
                  <li>Review messages later</li>
                  <li>Do not leave private notes visible</li>
                </ul>
              </article>
            </div>
            <div class="shield-layer">
              <img src={asset("app-icon.png")} alt="" width="74" height="74" />
              <strong>Notion Hidden</strong>
              <p>AegisLock is hiding this app while authentication is required.</p>
            </div>
          </div>

          <div class="auth-card">
            <div class="touch-animation" aria-hidden="true">
              <img class="touch-base" src={asset("touch-id-logo.svg")} alt="" width="66" height="66" />
              <span class="touch-fill"><img src={asset("touch-id-logo.svg")} alt="" width="66" height="66" /></span>
            </div>
            <div>
              <span>Unlock private app</span>
              <strong><span class="touch-inline">Touch ID</span> or Mac password required</strong>
              <p>Safe Hide keeps the app alive. Nothing quits.</p>
            </div>
            <button type="button" aria-live="polite">Authenticate</button>
          </div>

          <div class="report-chip">
            <span>Access Report</span>
            <strong>Allowed by system auth</strong>
          </div>
        </div>
      </section>

      <section id="why" class="section why-section">
        <div class="section-heading left">
          <p class="eyebrow">Why this matters now</p>
          <h2>Your Mac may need to stay awake. Your private apps do not need to <span class="accent">stay exposed.</span></h2>
          <p>
            AI agents, long uploads, downloads, render jobs, and shared spaces make unlocked Macs more common. AegisLock is for the moment when you step away, switch seats, share a desk, or let automation keep running.
          </p>
        </div>
        <div class="scenario-grid">
          <article>
            <span>Library</span>
            <p>Keep study tools open without leaving journals, messages, or personal notes visible.</p>
          </article>
          <article>
            <span>Office</span>
            <p>Let work continue while private browser profiles, chats, and documents stay hidden.</p>
          </article>
          <article>
            <span>Home</span>
            <p>Stop curious clicks from family or guests without locking the whole computer every time.</p>
          </article>
          <article>
            <span>Agents</span>
            <p>Allow local agent work through scoped approval instead of turning protection off.</p>
          </article>
        </div>
      </section>

      <section id="protection" class="section protection-section">
        <div class="section-heading">
          <p class="eyebrow">Protection model</p>
          <h2>Private apps stay <span class="accent">out of view.</span> Open work stays intact.</h2>
          <p>
            AegisLock is built around Safe Hide: hide the app surface, require system authentication to reveal it, and avoid the two common app-locker failures: readable overlays and forced quits that can lose work.
          </p>
        </div>
        <div class="mode-grid">
          <article class="mode-card recommended">
            <div class="mode-top">
              <span>Default</span>
              <strong>Safe Hide</strong>
            </div>
            <p>Best for documents, browsers, notes, editors, and apps with unsaved state.</p>
            <ul>
              <li>Hides the protected app surface</li>
              <li>Does not quit the app</li>
              <li>Requires auth before reveal</li>
            </ul>
          </article>
          <article class="mode-card">
            <div class="mode-top">
              <span>Optional</span>
              <strong>Strict Reopen</strong>
            </div>
            <p>For apps where restarting is acceptable and a stronger interruption is worth the tradeoff.</p>
            <ul>
              <li>Per-app opt-in</li>
              <li>Clear data-loss warning</li>
              <li>Not the default</li>
            </ul>
          </article>
          <article class="mode-card">
            <div class="mode-top">
              <span>Control</span>
              <strong>Unlock Grace</strong>
            </div>
            <p>Choose when access should end: on focus change, while open, after a short window, or at sleep.</p>
            <div class="segmented-demo" aria-hidden="true">
              <b>Focused</b><span>Open</span><span>5 min</span><span>15 min</span><span>Sleep</span>
            </div>
          </article>
        </div>
      </section>

      <section id="automation" class="section control-section">
        <div class="control-copy">
          <p class="eyebrow">Less friction</p>
          <h2>Protection should not <span class="accent">annoy you</span> into turning it off.</h2>
          <p>
            AegisLock gives you the controls that matter instead of a wall of settings. Work uninterrupted, relock quickly, or let trusted context decide.
          </p>
        </div>
        <div class="control-grid">
          <article class="control-card">
            <span>Focus Session</span>
            <strong>Unlock all protected apps for a short work block.</strong>
            <p>Start a time-boxed session when you are working deeply and do not want repeated prompts.</p>
          </article>
          <article class="control-card">
            <span>Trusted Places</span>
            <strong>Relax at trusted locations. Protect elsewhere.</strong>
            <p>Opt-in location rules can change protection by place. Unknown location falls back to protection.</p>
          </article>
          <article class="control-card">
            <span>Schedules</span>
            <strong>Match school, library, office, or evening routines.</strong>
            <p>Use time windows for predictable days without training yourself to toggle security manually.</p>
          </article>
          <article class="control-card agent-mini">
            <span>Agentic Work</span>
            <strong>Local agents may ask. They cannot silently pass.</strong>
            <p>Scoped app list, reason, duration, system auth, and a hard maximum for long-running work.</p>
          </article>
        </div>
      </section>

      <section id="reports" class="section reports-section">
        <div class="reports-copy">
          <p class="eyebrow">Access Reports</p>
          <h2>Know when access happened, <span class="accent">without logging</span> what you worked on.</h2>
          <p>
            AegisLock records security events locally with integrity checks. It avoids document names, window titles, typed content, and screenshots.
          </p>
        </div>
        <div class="audit-panel" aria-label="Access report preview">
          <div class="audit-header">
            <div>
              <span>Local audit trail</span>
              <strong>Verified</strong>
            </div>
            <button type="button">Export</button>
          </div>
          <div class="audit-row allowed">
            <i></i>
            <div><b>Notion revealed</b><span>System authentication approved</span></div>
            <time>14:29</time>
          </div>
          <div class="audit-row denied">
            <i></i>
            <div><b>Settings change blocked</b><span>Authentication cancelled</span></div>
            <time>14:21</time>
          </div>
          <div class="audit-row allowed">
            <i></i>
            <div><b>Agentic Work lease started</b><span>Codex, 30 minute scoped session</span></div>
            <time>13:58</time>
          </div>
        </div>
      </section>

      <section class="section build-section">
        <div class="build-card">
          <p class="eyebrow">Hardening</p>
          <h2>Built to <span class="accent">recover</span> from ordinary failure modes.</h2>
          <div class="build-grid">
            <article><span>Watchdog</span><p>Relaunches AegisLock after ordinary quits and restores protection state.</p></article>
            <article><span>Delete restore</span><p>Local restore checks help recover the app bundle after casual deletion.</p></article>
            <article><span>Auth-gated changes</span><p>Protection settings only commit after successful authentication.</p></article>
          </div>
        </div>
      </section>

      <section id="security" class="section security-section">
        <div class="section-heading left">
          <p class="eyebrow">Security boundary</p>
          <h2>Strong for casual access. Clear about <span class="accent">system limits.</span></h2>
          <p>
            AegisLock protects privacy during an already-unlocked Mac session. It is not a replacement for FileVault, device lock, MDM, or malware protection.
          </p>
        </div>
        <div class="security-grid">
          <article><span>Protects</span><p>Shared desks, accidental opens, app switching, weak overlays, and short unattended moments.</p></article>
          <article><span>Does not protect</span><p>Administrators, root users, malware, Recovery Mode, forensic access, or anyone with your Mac password.</p></article>
          <article><span>Best paired with</span><p>FileVault, automatic screen lock, strong Mac password, and normal macOS security updates.</p></article>
        </div>
      </section>

      <section id="pricing" class="section pricing-section">
        <div>
          <p class="eyebrow">Pricing</p>
          <h2>One Mac utility. <span class="accent">One-time license.</span></h2>
          <p>
            No subscription for a small privacy utility. Core protection, local reports, Agentic Work, schedules, Trusted Places, and updates for the current major version are included.
          </p>
        </div>
        <div class="price-panel">
          <span>Personal license</span>
          <strong>29 EUR</strong>
          <p>For one person using AegisLock on their own Macs.</p>
          <a class="button primary" href={repoUrl} target="_blank" rel="noreferrer">Download for Mac</a>
        </div>
      </section>
    </main>

    <footer class="site-footer">
      <div class="brand footer-brand">
        <img src={asset("app-icon.png")} alt="" width="30" height="30" />
        <span>AegisLock</span>
      </div>
      <p>Private Mac app protection. Local-first reports. Honest security model.</p>
      <div>
        <a href={repoUrl} target="_blank" rel="noreferrer">GitHub</a>
        <a href="#security">Security</a>
        <a href="#pricing">Pricing</a>
      </div>
    </footer>

    <script>
      const demo = document.querySelector(".hero-demo");
      const authButton = document.querySelector(".auth-card button");
      const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)");
      let unlockTimer;

      window.addEventListener("pointermove", (event) => {
        if (!demo || window.matchMedia("(max-width: 920px)").matches) {
          return;
        }

        const x = (event.clientX / window.innerWidth - 0.5) * 8;
        const y = (event.clientY / window.innerHeight - 0.5) * 6;
        demo.style.transform = `translate3d(${x}px, ${y}px, 0)`;
      });

      function resetHeroDemo() {
        if (!demo || !authButton) {
          return;
        }

        window.clearTimeout(unlockTimer);
        demo.classList.remove("is-authenticating", "is-unlocked");
        authButton.disabled = false;
        authButton.textContent = "Authenticate";
      }

      function unlockHeroDemo() {
        if (!demo || !authButton) {
          return;
        }

        if (demo.classList.contains("is-unlocked")) {
          resetHeroDemo();
          return;
        }

        window.clearTimeout(unlockTimer);
        demo.classList.remove("is-unlocked", "is-authenticating");
        demo.getBoundingClientRect();
        demo.classList.add("is-authenticating");
        authButton.disabled = true;
        authButton.textContent = "Reading Touch ID...";

        unlockTimer = window.setTimeout(() => {
          demo.classList.remove("is-authenticating");
          demo.classList.add("is-unlocked");
          authButton.disabled = false;
          authButton.textContent = "Lock demo again";
        }, prefersReducedMotion.matches ? 180 : 1550);
      }

      authButton?.addEventListener("click", unlockHeroDemo);
    </script>
  </body>
</html>
